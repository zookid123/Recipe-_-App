{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Flutter Web (127.0.0.1:8080)",
      "request": "launch",
      "type": "dart",
      "deviceId": "chrome",
      "args": [
        "--web-hostname", "127.0.0.1",
        "--web-port", "8080",
        "--web-browser-flag", "--disable-web-security",
        "--web-browser-flag", "--user-data-dir=C:/chrome_dev_data"
      ]
    }
  ]
}